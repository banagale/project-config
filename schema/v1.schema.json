{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/banagale/project-config/schema/v1.schema.json",
  "title": "project-config.yaml v1",
  "description": "Schema for project-config.yaml, a configuration format for software projects.",
  "type": "object",
  "required": ["schema_version", "repo"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Identifies which version of the specification the config targets."
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical project identifier. Should match the git repository name."
    },
    "description": {
      "type": ["string", "null"],
      "description": "Human-readable, one-line description of the project."
    },
    "canonical_branch": {
      "type": "string",
      "default": "main",
      "description": "The source-of-truth branch. All worktrees sync against this branch."
    },
    "remote": {
      "type": ["string", "null"],
      "default": "origin",
      "description": "Git remote name for push/fetch. Set to null for local-only mode (no remote operations)."
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["merge", "rebase", "ff-only"],
          "default": "merge",
          "description": "Git strategy for syncing landing branches with the canonical branch."
        },
        "push_landing": {
          "type": "boolean",
          "default": true,
          "description": "Whether to push landing branches to remote after sync."
        },
        "push_to_canonical": {
          "type": "boolean",
          "default": false,
          "description": "Whether to push directly to the canonical branch on the remote."
        }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "post_init": {
          "$ref": "#/$defs/hook",
          "description": "Script(s) to run after a new worktree is created."
        },
        "pre_sync_all": {
          "$ref": "#/$defs/hook",
          "description": "Script(s) to run once before any worktrees are synced."
        },
        "post_sync_all": {
          "$ref": "#/$defs/hook",
          "description": "Script(s) to run once after all worktrees are synced."
        },
        "pre_sync": {
          "$ref": "#/$defs/hook",
          "description": "Script(s) to run before each individual worktree syncs."
        },
        "post_sync": {
          "$ref": "#/$defs/hook",
          "description": "Script(s) to run after each individual worktree syncs."
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bloon", "none", "linear", "github", "jira"],
          "default": "none",
          "description": "Task management system. 'bloon' and 'none' are standardized; others are reserved."
        },
        "project": {
          "type": "string",
          "description": "Project name in the task system. Defaults to the repo value."
        },
        "default_priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "default": 2,
          "description": "Default priority for new tasks. 0=critical, 1=high, 2=medium, 3=low."
        },
        "autofocus": {
          "type": "boolean",
          "default": true,
          "description": "Whether to auto-focus newly created tasks."
        },
        "require_validation": {
          "type": "boolean",
          "default": false,
          "description": "Whether validation is required before marking a task done."
        },
        "tags_prefix": {
          "type": ["string", "null"],
          "default": null,
          "description": "Prefix applied to auto-generated tags."
        },
        "external": {
          "type": ["object", "null"],
          "default": null,
          "description": "External project management system integrations.",
          "properties": {
            "linear": {
              "type": "object",
              "properties": {
                "team": {
                  "type": "string",
                  "description": "Linear team prefix (e.g., 'ACME')."
                },
                "skill": {
                  "type": "string",
                  "description": "AI skill name for Linear operations."
                },
                "user_id": {
                  "type": "string",
                  "description": "User ID in Linear."
                }
              }
            },
            "github": {
              "type": "object",
              "properties": {
                "repo": {
                  "type": "string",
                  "pattern": "^[^/]+/[^/]+$",
                  "description": "GitHub repository in 'owner/repo' format."
                },
                "skill": {
                  "type": "string",
                  "description": "AI skill name for GitHub issue operations."
                }
              }
            }
          }
        }
      }
    },
    "cross_project_availability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "$ref": "#/$defs/availability",
          "default": "none",
          "description": "Which skills from this project are shared across projects."
        },
        "agents": {
          "$ref": "#/$defs/availability",
          "default": "none",
          "description": "Which agents from this project are shared across projects."
        }
      }
    },
    "color_palette": {
      "type": ["array", "null"],
      "default": null,
      "items": {
        "type": "string",
        "pattern": "^#[0-9A-Fa-f]{6}$"
      },
      "description": "Hex color palette for iTerm2 tab coloring."
    },
    "alias_prefix": {
      "type": ["string", "null"],
      "default": null,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "description": "Short prefix for shell aliases for worktree navigation."
    },
    "default_app": {
      "type": ["string", "null"],
      "default": null,
      "description": "Default application to launch for project-level run commands."
    },
    "extra_windows": {
      "type": ["array", "null"],
      "default": null,
      "items": {
        "type": "object",
        "required": ["title", "worktrees"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Window title."
          },
          "worktrees": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "Worktree names to open in this window."
          }
        }
      },
      "description": "Additional terminal windows beyond primary worktree tabs."
    },
    "worktrees": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/worktree"
      },
      "description": "Registry of git worktrees for the project."
    }
  },
  "$defs": {
    "hook": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "null" }
      ],
      "default": null
    },
    "availability": {
      "oneOf": [
        { "type": "string", "enum": ["all", "none"] },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "worktree": {
      "type": "object",
      "required": ["name", "path", "landing_branch"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Short identifier for the worktree."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path to the worktree directory."
        },
        "landing_branch": {
          "type": "string",
          "minLength": 1,
          "description": "The branch this worktree stays checked out on."
        },
        "archived": {
          "type": "boolean",
          "default": false,
          "description": "When true, excluded from sync-all and status operations."
        },
        "meta": {
          "type": "object",
          "default": {},
          "additionalProperties": true,
          "description": "Arbitrary metadata (color, role, ports, notes, etc.)."
        },
        "nested_repos": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["path", "landing_branch"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "description": "Path to nested repo, relative to worktree root."
              },
              "landing_branch": {
                "type": "string",
                "description": "Branch the nested repo stays on."
              },
              "remote": {
                "type": "string",
                "default": "origin",
                "description": "Git remote name for the nested repo."
              }
            }
          },
          "description": "Nested git repositories within the worktree."
        }
      }
    }
  }
}
